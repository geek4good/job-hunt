#!/usr/bin/env bash
# mise task: ollama — ensure Ollama server is running and the model is pulled.
#
# This script is idempotent:
#   1. If ollama serve is already running, skip.
#   2. If not, start it in the background and wait for readiness.
#   3. Pull the model if not already available.

set -euo pipefail

MODEL="${OLLAMA_MODEL:-gemma4:e4b}"
URL="${OLLAMA_URL:-http://localhost:11434}"

# --- Check if Ollama is already serving ---
if curl -sf "${URL}/api/tags" > /dev/null 2>&1; then
  echo "✔ Ollama already running at ${URL}"
else
  echo "▶ Starting Ollama server..."
  ollama serve &>/tmp/ollama-serve.log &
  OLLAMA_PID=$!

  # Wait up to 30s for readiness
  for i in $(seq 1 30); do
    if curl -sf "${URL}/api/tags" > /dev/null 2>&1; then
      echo "✔ Ollama ready (pid ${OLLAMA_PID})"
      break
    fi
    if [ "$i" -eq 30 ]; then
      echo "✘ Ollama failed to start. See /tmp/ollama-serve.log"
      cat /tmp/ollama-serve.log
      exit 1
    fi
    sleep 1
  done
fi

# --- Ensure the model is pulled ---
if ollama list 2>/dev/null | grep -q "${MODEL}"; then
  echo "✔ Model ${MODEL} already available"
else
  echo "▶ Pulling model ${MODEL}..."
  ollama pull "${MODEL}"
  echo "✔ Model ${MODEL} ready"
fi
